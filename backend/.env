# ============================================================
# 古代栈道结构力学仿真与风化评估系统 - 后端配置
# ============================================================

# 服务配置
SERVER_PORT=8080
SERVER_MODE=debug

# TimescaleDB 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=plankroad_monitor
DB_SSLMODE=disable
DB_POOL_MAX=25

# MQTT 配置
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=plankroad_backend
MQTT_USERNAME=admin
MQTT_PASSWORD=admin
MQTT_ALARM_TOPIC=plankroad/alarm/+
MQTT_DATA_TOPIC=plankroad/data/+

# 仿真计算配置
FEM_ELEMENT_SIZE=0.1           # 有限元网格大小 (m)
FEM_MAX_ITERATIONS=1000        # 最大迭代次数
FEM_TOLERANCE=1e-6             # 收敛容差

# 风化评估配置
FREEZE_TEMP_THRESHOLD=0.0      # 冻结温度阈值 (°C)
THAW_TEMP_THRESHOLD=2.0        # 融化温度阈值 (°C)
CRITICAL_CRACK_DEPTH=50.0      # 临界裂隙深度 (mm)
WOOD_DESIGN_LIFE=200.0         # 木材设计寿命 (年)
ROCK_DESIGN_LIFE=1000.0        # 岩体设计寿命 (年)
